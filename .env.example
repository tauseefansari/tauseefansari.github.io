# GitHub username — used for project card preview images (raw.githubusercontent.com).
# CI sets this from the repository owner automatically; set locally for dev.
VITE_GITHUB_USERNAME=tauseefansari

# Optional resume PDF URL — when set, the hero shows a download button.
# Leave empty or omit locally to hide the button.
VITE_RESUME_URL=your-resume-url

# Web3Forms access key for the contact form.
# Create a free key at https://web3forms.com (it is a PUBLIC key, safe to ship;
# your real email is configured on Web3Forms' side and never exposed here).
VITE_WEB3FORMS_KEY=your-public-access-key

# GitHub Pages project-site base path (CI sets this automatically).
# VITE_BASE=/portfolio/
