    "framer-motion": "^12.0.0",
    "gsap": "^3.12.5",
    "i18next": "^24.0.0",
    "js-cookie": "^3.0.5",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.1.0",
    "simple-icons": "^16.22.0",
    "three": "^0.171.0",
    "zustand": "^5.0.0"
